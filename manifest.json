{
    "manifest_version": 3,
    "name": "Custom New Tab Page",
    "version": "1.0",
    "description": "A custom new tab page for Chrome",
    "permissions": [
        "storage"
    ],
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "https://cn.bing.com/*"
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}